books = []

while True:
    choice = input("enter your choice")
    if choice == "1":
        book = input("enter book name: ")
        books.append(book)
        print("book added ")
    elif choice == "2":
        if len(books) == 0:
            print("No books in library.")
        else:
            print(" Books available")
            for b in books:
                print( b)
    elif choice == "3":
        book = input("enter book ")
        if book in books:
            books.remove(book)
            print("book removed ")
        else:
            print("book not found")
    else:
        print("not now come again") 
