class Calculator:
    def addition(self, num1, num2):
        return num1 + num2
    def sub(self, num1, num2):
        return num1 - num2
    def mul(self, num1, num2):
        return num1 * num2
    def div(self, num1, num2):
        if num2 == 0:
            return
        return num1 / num2
calc = Calculator()

print(calc.addition(10, 5))
print(calc.sub(10, 5))
print(calc.mul(10, 5))
print(calc.div(10, 5))
print(calc.div(10, 0))
